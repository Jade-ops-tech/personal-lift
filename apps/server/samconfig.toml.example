# 复制为 samconfig.toml（已被 .gitignore，含密钥勿提交）。
# 或直接运行 `sam deploy --guided` 让它交互式生成。
version = 0.1

[default.deploy.parameters]
stack_name = "personal-lift-api"
region = "us-east-1"
resolve_s3 = true
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
parameter_overrides = [
  "DatabaseUrl=postgresql://USER:PASSWORD@HOST/DB?sslmode=require",
  "BetterAuthSecret=请替换为至少32位的随机串",
  "CorsOrigin=https://你的前端域名",
  "BetterAuthUrl=http://localhost:3000",
]
