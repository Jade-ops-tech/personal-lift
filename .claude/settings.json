{
  "permissions": {
    "allow": [
      "Bash(git push *)",
      "Bash(pnpm check *)",
      "Bash(git commit -m ' *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm run fix --skip=correctness/noUnusedImports"
          }
        ]
      }
    ]
  }
}
